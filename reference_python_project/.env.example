# ═══════════════════════════════════════════════════════════════════════════
# OPENCLAW · POLYMARKET ARB BOT — CONFIGURATION TEMPLATE
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. Copy this file:   cp .env.example .env   (Linux/Mac/Git Bash)
#                      copy .env.example .env  (Windows CMD)
# 2. Fill in your credentials below.
# 3. NEVER commit .env — it is already in .gitignore.
#
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# POLYMARKET CREDENTIALS
# ───────────────────────────────────────────────────────────────────────────
# Your Polygon wallet private key (used to sign orders — never shared).
# How to get it: MetaMask → Account Details → Export Private Key
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Your wallet address on Polygon (the "funder" / USDC holder).
# How to get it: https://polymarket.com/settings → copy the address (starts with 0x)
POLYMARKET_FUNDER=0xYOUR_WALLET_ADDRESS_HERE

# Signature type:
#   1 = EIP-712 proxy wallet (default — Polymarket's standard login via MetaMask)
#   0 = EOA direct signing (advanced — only if you know what this means)
POLYMARKET_SIGNATURE_TYPE=1

POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137

# ───────────────────────────────────────────────────────────────────────────
# STRATEGY
# ───────────────────────────────────────────────────────────────────────────
# latency_arb  → exploit ~2.7s Binance→Polymarket lag (requires Binance WebSocket)
# dump_hedge   → structural arb: buy YES+NO when combined < $1.00 (no Binance needed)
# both         → run both strategies simultaneously
STRATEGY=dump_hedge

# ───────────────────────────────────────────────────────────────────────────
# TRADING MARKETS
# ───────────────────────────────────────────────────────────────────────────
# Comma-separated list of markets to trade. Valid values: btc, eth, sol, xrp
#
# Examples:
#   MARKETS=btc          → BTC only (most liquid, recommended for small balance)
#   MARKETS=btc,eth      → BTC + ETH
#   MARKETS=btc,eth,sol  → all three (default)
#   MARKETS=btc,eth,sol,xrp → all four markets
#
# Note: more markets = more CPU usage and API calls.
# Start with btc only if your balance is small or your connection is unstable.
MARKETS=btc,eth,sol

# TRADE WINDOW
# ─────────────────────────────────────────────────────────────────────────────
# Which up/down market series to trade. Must be exactly 5 or 15.
#
#   5  → "Bitcoin Up or Down - 5 Minutes"  — resolves every 5 min, highest
#         volume and tightest spreads. Best for capturing the 2.7s lag edge.
#
#  15  → "Bitcoin Up or Down - 15 Minutes" — resolves every 15 min, slower
#         price discovery, slightly less competition. Useful when 5-min
#         markets are low liquidity.
#
# Changing this also changes the default POSITION_TIMEOUT_SECONDS (300 or 900)
# so positions always close before the window resolves.
TRADE_WINDOW_MINUTES=5

# ───────────────────────────────────────────────────────────────────────────
# TRADING MODE
# ───────────────────────────────────────────────────────────────────────────
# Always start with PAPER_MODE=true. Run at least 20+ paper trades before live.
PAPER_MODE=false
PAPER_STARTING_BALANCE=1000.0

# ───────────────────────────────────────────────────────────────────────────
# DUMP-HEDGE STRATEGY PARAMETERS
# ───────────────────────────────────────────────────────────────────────────
# Only active when STRATEGY=dump_hedge or STRATEGY=both

# Maximum combined YES+NO ask price to enter. Below $1.00 = structural profit.
# 0.93 = enter only when combined ≤ 93¢ (≥7¢ discount — survives REST latency)
DH_SUM_TARGET=0.93

# Minimum discount per share (1.0 - combined). Guards against fees.
DH_MIN_DISCOUNT=0.02

# Total USDC to spend per DH trade (split ~50/50 across both legs).
# Polymarket minimum is $1.00 per leg. Use $5+ to safely clear that minimum.
DH_FIXED_BET_USDC=5

# Early-exit: sell when realised profit reaches this fraction of locked profit.
# 0.70 = exit at 70% of max possible profit (don't wait for market to resolve)
DH_EARLY_EXIT_PROFIT_FRACTION=0.70

# Force-close DH position after this many seconds. Auto-derived: 90% of window.
# 5-min window → 270s | 15-min window → 810s. Uncomment to override.
# DH_TIMEOUT_SECONDS=270

# Cooldown between DH signals on the same asset (seconds).
DH_COOLDOWN_SECONDS=30.0

# ───────────────────────────────────────────────────────────────────────────
# EDGE DETECTION — LATENCY ARB PARAMETERS
# ───────────────────────────────────────────────────────────────────────────
# Only active when STRATEGY=latency_arb or STRATEGY=both

# Measured Binance→Polymarket lag. Do not go below 2.0.
EDGE_LAG_WINDOW_SECONDS=2.7

# Minimum probability edge to fire a trade (0.05 = 5% advantage)
EDGE_MIN_EDGE_THRESHOLD=0.05

# Per-asset cooldown after any trade (seconds)
EDGE_COOLDOWN_SECONDS=5.0

# Minimum market USDC liquidity to qualify (skip thin markets)
EDGE_MIN_MARKET_LIQUIDITY=500

# Entry zone: only trade tokens priced in this range.
# [0.38, 0.62] = near-50/50 zone where latency arb has maximum impact.
EDGE_MIN_ENTRY_PRICE=0.38
EDGE_MAX_ENTRY_PRICE=0.62

# Minimum sigmoid conviction: abs(fair_value - 0.5) must be ≥ this.
# Prevents fake edges when asset price hasn't moved meaningfully.
EDGE_MIN_FAIR_VALUE_STRENGTH=0.05

# Minimum seconds remaining before entry. Auto: 20% of window (60s / 180s).
# EDGE_MIN_SECONDS_REMAINING=60

# ───────────────────────────────────────────────────────────────────────────
# STOP LOSS / TAKE PROFIT — EXIT THRESHOLDS
# ───────────────────────────────────────────────────────────────────────────

# Sell when YES token price reaches this level
TAKE_PROFIT_PRICE=0.72

# Sell when unrealised PnL % reaches this target
TAKE_PROFIT_PNL=0.12

# Sell to cut losses when PnL % falls below this. MUST BE NEGATIVE.
# Set to 0.0 to disable stop loss (not recommended).
STOP_LOSS_PNL=-0.20

# Sell early when price approaches resolution
NEAR_WIN_PRICE=0.92
NEAR_LOSS_PRICE=0.08

# Force-close any position older than this (seconds).
# Auto-derived: 300s for 5-min window, 900s for 15-min window.
# POSITION_TIMEOUT_SECONDS=300

# ───────────────────────────────────────────────────────────────────────────
# RISK MANAGEMENT
# ───────────────────────────────────────────────────────────────────────────

# Max single position size as fraction of balance (0.50 = 50%)
RISK_MAX_POSITION_FRACTION=0.50

# Kelly toggle: true = Kelly formula, false = fixed bet
KELLY_ENABLED=false

# Fixed USDC per trade (Polymarket minimum is $1.00 per leg)
RISK_FIXED_BET_USDC=20

# Kelly fraction multiplier (used when KELLY_ENABLED=true). 0.3 = conservative.
RISK_KELLY_FRACTION=0.3

# Pause trading if daily loss exceeds this fraction of daily starting balance
RISK_DAILY_LOSS_LIMIT=0.50

# Permanent halt if drawdown from peak exceeds this. 1.0 = effectively disabled.
RISK_TOTAL_DRAWDOWN_KILL=0.40

# Max simultaneous open positions (across all strategies and assets)
RISK_MAX_CONCURRENT_POSITIONS=3

# ───────────────────────────────────────────────────────────────────────────
# TELEGRAM NOTIFICATIONS
# ───────────────────────────────────────────────────────────────────────────
# Setup:
#   1. Open Telegram → @BotFather → /newbot → follow prompts → copy token
#   2. Open @userinfobot → copy your numeric chat ID
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_NUMERIC_CHAT_ID_HERE
TELEGRAM_ENABLED=false

# ───────────────────────────────────────────────────────────────────────────
# OPENCLAW AGENT INTEGRATION (optional)
# ───────────────────────────────────────────────────────────────────────────
# Enable/disable OpenClaw AI agent integration
# true  = bot sends reports and receives commands from the OpenClaw agent
# false = integration fully disabled, all API calls are skipped
OPENCLAW_ENABLED=false
OPENCLAW_API_KEY=YOUR_OPENCLAW_API_KEY_HERE
OPENCLAW_API_URL=https://app.openclaw.ai/api
OPENCLAW_AGENT_ID=main
OPENCLAW_REPORT_INTERVAL=300

# ───────────────────────────────────────────────────────────────────────────
# LOGGING
# ───────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=polymarket_bot.log
DASHBOARD_LOG_LINES=10        # Number of recent log lines shown in the dashboard log panel
