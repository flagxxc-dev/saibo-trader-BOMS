# ══════════════════════════════════════════════════════════════════════════════
#  POLYMARKET — .dockerignore
#  Excludes files that must NOT be baked into the Docker image.
# ══════════════════════════════════════════════════════════════════════════════

# ── SECURITY: never bake secrets into the image ───────────────────────────────
.env
*.key
*.pem
*.p12

# ── Python virtual environment ────────────────────────────────────────────────
# The image installs deps fresh via requirements.txt — venv is not needed.
venv/
.venv/
env/

# ── Python byte-code and caches ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.eggs/
*.egg-info/
build/
dist/

# ── Linter / type-checker caches ─────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ── Log files (written to the mounted volume at runtime) ─────────────────────
*.log
*.log.*
logs/

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Tests (not needed at runtime inside the container) ───────────────────────
tests/

# ── Documentation (not needed inside the container) ──────────────────────────
README.md
CHANGELOG.md

# ── Claude Code settings ─────────────────────────────────────────────────────
.claude/
