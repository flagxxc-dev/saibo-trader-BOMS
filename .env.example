PAPER_MODE=true
POLYMARKET_CHAIN_ID=137
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_FUNDER=0xYourPolygonWalletAddress
POLYMARKET_PRIVATE_KEY=0xYourWalletPrivateKey
PAPER_STARTING_BALANCE=1000.0

# 纸面盘持久化：重启后保留余额、持仓、成交历史（存 logs/paper_state.json）
PAPER_STATE_PERSIST=true
PAPER_STATE_PATH=logs/paper_state.json

RISK_MAX_POSITION_FRACTION=0.08
RISK_DAILY_LOSS_LIMIT=0.20
RISK_TOTAL_DRAWDOWN_KILL=0.40
RISK_MAX_CONCURRENT_POSITIONS=10

FEE_RATE=0.018

# Strategy: latency_arb | dump_hedge | both
# dump_hedge = 只跑 DH，关闭 LA 下单
STRATEGY=dump_hedge

# Binance 现货行情（仪表盘走势）；与 STRATEGY 独立，关闭 LA 时仍可订阅
BINANCE_FEED_ENABLED=true

# Strategy (reference_python_project defaults)
DH_SUM_TARGET=0.95
DH_MIN_DISCOUNT=0.03
DH_COOLDOWN_SECONDS=30
EDGE_MIN_EDGE_THRESHOLD=0.04
EDGE_COOLDOWN_SECONDS=5
EDGE_MIN_SECONDS_REMAINING=60
EDGE_MIN_FAIR_VALUE_STRENGTH=0.05
ENTRY_PRICE_MIN=0.38
ENTRY_PRICE_MAX=0.62

# LA Strategy Tuning
TRAILING_STOP_ACTIVATION=0.06
TRAILING_STOP_DISTANCE=0.04
STOP_LOSS_PNL=-0.10

# Exit Thresholds (Latency Arb only)
NEAR_WIN_PRICE=0.92
NEAR_LOSS_PRICE=0.08
TAKE_PROFIT_PRICE=0.72
TAKE_PROFIT_PNL=0.12
STOP_LOSS_PNL=-0.20
POSITION_TIMEOUT_SECONDS=250
