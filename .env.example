POLYMARKET_CHAIN_ID=137
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_FUNDER=0xYourPolygonWalletAddress
POLYMARKET_SIGNER=0xYourMetaMaskOrExportedWalletAddress
POLYMARKET_PRIVATE_KEY=0xYourWalletPrivateKey

RISK_MAX_POSITION_FRACTION=0.08
RISK_DAILY_LOSS_LIMIT=0.20
RISK_TOTAL_DRAWDOWN_KILL=0.40
RISK_MAX_CONCURRENT_POSITIONS=10

FEE_RATE=0.018

# Binance 现货行情（仪表盘走势，不参与 DH 开仓）
BINANCE_FEED_ENABLED=true

# DH 结构对冲（LIH_ENABLED=false 时作为唯一策略；LIH 开启时仅作市场开关 DH_ENABLE_*）
DH_SUM_TARGET=0.95
DH_MIN_DISCOUNT=0.03
DH_COOLDOWN_SECONDS=30
DH_MIN_SECONDS_REMAINING=60
# 按窗口开关（false = 该周期不开新仓）
DH_ENABLE_5M=true
DH_ENABLE_15M=true
# 窗口内按币种开关（窗口关时全部不交易，与下列无关）
DH_ENABLE_5M_BTC=true
DH_ENABLE_5M_ETH=true
DH_ENABLE_5M_SOL=true
DH_ENABLE_15M_BTC=true
DH_ENABLE_15M_ETH=true

MIN_ORDER_SIZE=5.0

# Live only: validate DH against REST best-ask book; log WOULD OPEN but do not POST orders
LIVE_DH_DRY_RUN=false
# Live only: validate LIH legs against REST book; default true = shadow only, no CLOB POST
LIVE_LIH_DRY_RUN=true
# 实盘 DH：REST+WS 订单簿感知检测（A+B+C）。关则回退旧 WS 检测逻辑。
DH_BOOK_AWARE_DETECT=true

# Live LIH state (open/closed rounds, session counters)
# Leg-in hedge (primary strategy when LIH_ENABLED=true; DH not run)
LIH_ENABLED=true
LIH_USE_MIRROR=false
# Leg1 mode: cheap = buy ask≤LEG1_MAX (default VPS); trend = buy Binance-trend side up to TREND_MAX
LIH_LEG1_MODE=trend
LIH_LEG1_TREND_MAX_PRICE=0.65
LIH_LEG1_MAX_PRICE=0.45
LIH_TARGET_COMBINED=0.94
LIH_LEG1_SHARES=10
# No leg1 for first N seconds after 5m/15m window opens (wait opening volatility; not forced entry)
LIH_LEG1_START_DELAY_SEC=7
LIH_ALLOW_OVER_TARGET=true
# Last N seconds: hedge light leg even if marginal > target (loss-cap fallback)
LIH_FORCE_BALANCE_SECS=60
# Block leg1 against Binance short-term move (YES when spot up, NO when spot down)
LIH_LEG1_TREND_ALIGN=false
LIH_TREND_LOOKBACK_SEC=60
# Endgame: start batch hedge at T-N; override breaks soft cap in last M seconds
LIH_ENDGAME_SECS=100
LIH_ENDGAME_HOLD_ASK=0.90
LIH_ENDGAME_RESUME_HEDGE_ASK=0.89
LIH_ENDGAME_SOFT_CAP=1.15
LIH_ENDGAME_STEP_SHARES_SMALL=5
LIH_ENDGAME_STEP_SHARES_LARGE=10
LIH_ENDGAME_GAP_LARGE=10
LIH_ENDGAME_OVERRIDE_SECS=50
LIH_ENDGAME_OVERRIDE_COOLDOWN=2
LIH_REBALANCE_MODE=flex
LIH_FLEX_DILUTE_RATIO=0.95
# 0 = budget-driven only (balance × RISK_MAX_POSITION_FRACTION); >0 optional share ceiling
LIH_MAX_REBALANCE_SHARES=0
LIH_MAX_MATCHED_SHARES=50
# Per market slot (asset+window) cumulative USDC cap for the whole round; 0 = balance × RISK_MAX_POSITION_FRACTION
LIH_MAX_USDC_PER_SLOT=0
LIH_MIN_SECONDS_REMAINING=15
# No new leg1 when fewer seconds remain (skip late window; wait for next 5m round)
LIH_LEG1_MIN_SECONDS_REMAINING=30
LIH_COOLDOWN_SECONDS=0
# Split cooldowns (recommended): leg1 anti-spam, rebalance catch hedge prices
LIH_LEG1_COOLDOWN_SECONDS=20
LIH_REBALANCE_COOLDOWN_SECONDS=5
# Conservative rollout: one market slot at a time; stop new leg1 after N live legs this session
LIH_ONE_SLOT_GLOBAL=true
# 0 = unlimited (continuous live). >0 caps legs per session — enforced only if DEBUG gates re-enabled in RiskManager.cpp
LIH_SESSION_MAX_LEGS=0
# true = auto-pause after each round (debug/test). false = run continuously; session resets on round close
LIH_PAUSE_AFTER_ROUND=false
# Minimum wallet USDC before new leg1 (10sh @0.45 + hedge ≈ $9.5; use $10 buffer)
LIH_MIN_BALANCE_USDC=10
# Per-slot cumulative spend cap for one round (leg1 + hedge)
LIH_MAX_USDC_PER_SLOT=10
LIVE_MIRROR_PATH=logs/live_mirror.json

# 实盘余额同步间隔（秒）：trading-core + dashboard 钱包显示，默认 2
WALLET_SYNC_INTERVAL_SEC=2
# 链上 LIH 持仓对齐：兜底全量 reconcile 间隔（秒），默认 10；成交后会另触发 --positions-only
LIH_CHAIN_RECONCILE_SEC=10
# dashboard_bridge 维护线程是否跑链上 reconcile（实盘 LIVE_LIH_DRY_RUN=false 时）
LIVE_LIH_RECONCILE_ENABLED=true
# Gamma Up-Down 市场列表刷新间隔（秒）：新 5m/15m 窗口切换，默认 5（不宜低于 3）
GAMMA_MARKET_REFRESH_SEC=5

# Bot HTTP API bind (127.0.0.1 = localhost only; WS still uses WS_HOST)
HTTP_BIND=127.0.0.1
# Optional: require X-Bot-Api-Token on POST /api/config|control|mirror (set same value in web.env)
# BOT_API_TOKEN=

# Live only: after DH expiry, redeem conditional tokens on Polygon (requires web3 + MATIC for gas)
AUTO_REDEEM=true
