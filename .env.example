PAPER_MODE=true
POLYMARKET_CHAIN_ID=137
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_FUNDER=0xYourPolygonWalletAddress
POLYMARKET_SIGNER=0xYourMetaMaskOrExportedWalletAddress
POLYMARKET_PRIVATE_KEY=0xYourWalletPrivateKey
PAPER_STARTING_BALANCE=1000.0

# 纸面盘持久化：重启后保留余额、持仓、成交历史（存 logs/paper_state.json）
PAPER_STATE_PERSIST=true
PAPER_STATE_PATH=logs/paper_state.json

RISK_MAX_POSITION_FRACTION=0.08
RISK_DAILY_LOSS_LIMIT=0.20
RISK_TOTAL_DRAWDOWN_KILL=0.40
RISK_MAX_CONCURRENT_POSITIONS=10

FEE_RATE=0.018

# Binance 现货行情（仪表盘走势，不参与 DH 开仓）
BINANCE_FEED_ENABLED=true

# DH 结构对冲（唯一策略）
DH_SUM_TARGET=0.95
DH_MIN_DISCOUNT=0.03
DH_COOLDOWN_SECONDS=30
DH_MIN_SECONDS_REMAINING=60
# 按窗口开关（false = 该周期不开新仓）
DH_ENABLE_5M=true
DH_ENABLE_15M=true
# 窗口内按币种开关（窗口关时全部不交易，与下列无关）
DH_ENABLE_5M_BTC=true
DH_ENABLE_5M_ETH=true
DH_ENABLE_5M_SOL=true
DH_ENABLE_15M_BTC=true
DH_ENABLE_15M_ETH=true

MIN_ORDER_SIZE=5.0

# Live only: validate DH against REST best-ask book; log WOULD OPEN but do not POST orders
LIVE_DH_DRY_RUN=false

# Live only: after DH expiry, redeem conditional tokens on Polygon (requires web3 + MATIC for gas)
AUTO_REDEEM=true
