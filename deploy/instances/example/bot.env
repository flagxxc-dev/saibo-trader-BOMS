# 实例 bot-a — LIH 纸面示例
# 实盘时: PAPER_MODE=false（LIH 实盘下单尚未接入，请先纸面验证）

PAPER_MODE=true
BINANCE_FEED_ENABLED=true
POLYMARKET_CHAIN_ID=137
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_FUNDER=0xYourPolygonWalletAddress
POLYMARKET_PRIVATE_KEY=0xYourWalletPrivateKey
PAPER_STARTING_BALANCE=1000.0
PAPER_STATE_PERSIST=true
PAPER_STATE_PATH=logs/paper_state.json

RISK_MAX_POSITION_FRACTION=0.20
RISK_DAILY_LOSS_LIMIT=0.20
RISK_TOTAL_DRAWDOWN_KILL=0.40
RISK_MAX_CONCURRENT_POSITIONS=10

FEE_RATE=0.018
MIN_ORDER_SIZE=5.0

# 市场开关（LIH / DH 共用）
DH_ENABLE_5M=true
DH_ENABLE_15M=false
DH_ENABLE_5M_BTC=true
DH_ENABLE_5M_ETH=true
DH_ENABLE_5M_SOL=true
DH_ENABLE_15M_BTC=false
DH_ENABLE_15M_ETH=false

# LIH 主策略
LIH_ENABLED=true
LIH_USE_MIRROR=false
LIH_LEG1_MAX_PRICE=0.45
LIH_TARGET_COMBINED=0.95
LIH_LEG1_SHARES=10
LIH_FORCE_BALANCE_SECS=45
LIH_REBALANCE_MODE=flex
LIH_MAX_MATCHED_SHARES=50
LIH_MAX_REBALANCE_SHARES=0
LIH_MIN_SECONDS_REMAINING=90
LIH_COOLDOWN_SECONDS=0

PAPER_OFFICIAL_BOOK=true
PAPER_SLIPPAGE_PCT=0.005
PAPER_DEPTH_SIM=true

AUTO_REDEEM=true
