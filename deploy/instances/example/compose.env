# 单实例环境变量（复制为 deploy/instances/<名称>/.env 后修改）
# 用法: docker compose -p bot-a --env-file deploy/instances/bot-a/compose.env up -d

# 实例标识（用于容器名、网络、数据卷隔离）
INSTANCE_NAME=bot-a

# 宿主机端口（每个实例必须不同）
BOT_HTTP_PORT=8080
FRONTEND_HTTP_PORT=3001

# 前端
NEXTAUTH_URL=http://127.0.0.1:3001
NEXTAUTH_SECRET=change-me-in-production-use-long-random-string

# 若服务器在代理后，改为实际域名
# NEXTAUTH_URL=https://trade.example.com

# Bot 配置与日志（相对项目根目录，每实例一份）
BOT_ENV_FILE=./deploy/instances/bot-a/bot.env
BOT_LOG_DIR=./deploy/instances/bot-a/logs
